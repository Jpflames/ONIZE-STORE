# =========================================================================
# ONIZE Environment Variables Template
# =========================================================================
# This file defines the environment variables required for the ONIZE platform.
# Copy this file to .env.local and fill in your actual credentials.

# -------------------------------------------------------------------------
# 1. Clerk Authentication
# -------------------------------------------------------------------------
# Get these keys from the Clerk Dashboard (https://dashboard.clerk.com)
# Go to: API Keys -> Publishable key & Secret key
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_c2VjdXJlLW9yY2EtMjAuY2xlcmsuYWNjb3VudHMuZGV2JA
CLERK_SECRET_KEY=sk_test_2cXVU9ANJLbKjnHhjkGJw7MexJFvydAZGSvzOoQgJn
# -------------------------------------------------------------------------
# 2. Sanity CMS (Headless CMS)
# -------------------------------------------------------------------------
# Manage your project at https://www.sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=mte315z8
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-02-19

# Create an API token at: Sanity Manage -> Settings -> API -> Add new token
# Ensure it has "Editor" or "Administrator" permissions for server actions.
SANITY_API_TOKEN=skGFXb7QRucibLz9irWfCXrFSJaKmLEd3VqWTCWKaCrRr6qXLJ8RNWoX926ffX1NX6jANR9ovOMy9bNIQVWQ3IZYerxvZixma3c0ho8AQrxHmRkiDc4zl33T6AaIFTyC91KzHfacz7aKrA8nF3Bd0Z2cnO9ZWPvpIP4AmN7GMNwT19EQ51xV
SANITY_API_READ_TOKEN=skDdURYa3j15w4FfIb9RPoLMacWeBud6HqYrJpBE3WmOAJOoyn1aN9S04Cfs219U82hmGlDeP7p6kQfJYB99rEsYRkDL29e6rXsWXmf4wgSMBdsXCyMCBmrsRqdtbohAcfHsedWQ4c1sXNQ0oijC6HqLlUnlDiqetmKjbmpzHr408fyDdhwE

# -------------------------------------------------------------------------
# 3. Flutterwave Payments
# -------------------------------------------------------------------------
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-your_public_key
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-your_secret_key
FLUTTERWAVE_SECRET_HASH=your_flutterwave_webhook_hash

# -------------------------------------------------------------------------
# 4. Application Configuration
# -------------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# The email address of the Clerk user who will have Admin Dashboard access
ADMIN_EMAIL=your_email@example.com

# -------------------------------------------------------------------------
# Useful Commands & Notes
# -------------------------------------------------------------------------
# Export Sanity dataset: sanity dataset export production ./seed.tar.gz
# Import Sanity dataset: npx sanity@latest dataset import seed.tar.gz
# Production Webhook: https://your-domain.com/api/flutterwave-webhook